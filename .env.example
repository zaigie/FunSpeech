# FunSpeech docker-compose 环境变量样例
# 复制为 .env 后 docker compose 会自动读取
#
# 启动:
#   docker compose build
#   docker compose up -d                          # 默认: gateway + qwen3-asr + cosyvoice
#   docker compose --profile dolphin up -d        # 加上 dolphin
#   TTS_ENGINE=qwen3-tts docker compose up -d gateway qwen3-asr-0 qwen3-tts-0 # 改用 Qwen3-TTS
#   TTS_ENGINE=qwen3-tts-vllm-omni docker compose up -d gateway qwen3-asr-0 qwen3-tts-vllm-omni-0
#   TTS_ENGINE=cosyvoice3-vllm-omni docker compose up -d gateway qwen3-asr-0 cosyvoice3-vllm-omni-0
#   docker compose --profile funasr --profile dolphin up -d       # 全部 ASR 引擎


# ---------- 构建期 HTTP 代理 (可选) ----------
# 大陆网络下载 PyPI / HuggingFace 慢, 用本机代理加速 docker build:
# (host.docker.internal 在 Docker Desktop 上工作; Linux 服务器请改成宿主机 LAN IP)
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,*.local


# ---------- 端口 ----------
GATEWAY_PORT=8000


# ---------- 鉴权 ----------
# 网关侧外部鉴权(可选; 未设置 = 鉴权可选)
# APPTOKEN=your_secret_token
# APPKEY=your_app_key
# 网关到子服务的内部鉴权(强烈建议设置, 默认值仅用于本地)
INTERNAL_SERVICE_TOKEN=funspeech-internal


# ---------- 日志 ----------
LOG_LEVEL=INFO


# ---------- ASR 配置 ----------
# all / offline / realtime — funasr 子服务和网关都读这个
ASR_MODEL_MODE=all
# 流式中间结果是否带标点 (会增加延迟)
ASR_ENABLE_REALTIME_PUNC=false
# 启动时预热的额外 ASR 模型 id (逗号分隔, 配合 docker compose --profile)
# 例如: AUTO_LOAD_CUSTOM_ASR_MODELS=sensevoice-small,dolphin-small
AUTO_LOAD_CUSTOM_ASR_MODELS=


# ---------- 子服务 URL (逗号分隔可配多副本;第一个 TTS URL 是音色写副本) ----------
FUNASR_SERVICE_URLS=http://funasr-0:8001
DOLPHIN_SERVICE_URLS=http://dolphin-0:8002
QWEN3_ASR_SERVICE_URLS=http://qwen3-asr-0:8003
COSYVOICE_SERVICE_URLS=http://cosyvoice-0:8004
QWEN3_TTS_SERVICE_URLS=http://qwen3-tts-0:8005
QWEN3_TTS_VLLM_OMNI_SERVICE_URLS=http://qwen3-tts-vllm-omni-0:8006
COSYVOICE3_VLLM_OMNI_SERVICE_URLS=http://cosyvoice3-vllm-omni-0:8007


# ---------- TTS 配置 ----------
# TTS 引擎: cosyvoice / qwen3-tts / qwen3-tts-vllm-omni / cosyvoice3-vllm-omni
TTS_ENGINE=cosyvoice
# legacy CosyVoice: all / sft / clone。
# 网关也用它过滤音色列表;其它 TTS 后端实际模型形态以对应子服务 env 为准。
TTS_MODEL_MODE=all
# 克隆模型版本: cosyvoice2 / cosyvoice3
CLONE_MODEL_VERSION=cosyvoice3
# CosyVoice3 模型 ID (可换分支)
COSYVOICE3_MODEL_ID=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
# TensorRT 加速 (CosyVoice3 + FP16 + TRT 存在 NaN 风险, 建议 FP16=false)
TTS_LOAD_TRT=false
TTS_ENABLE_FP16=false
# vLLM 加速 LLM 阶段 (与本子服务的 transformers 4.51.3 冲突,
# 启用前请确认 — 见 services/cosyvoice/README.md)
TTS_LOAD_VLLM=false

# Qwen3-TTS 开源本地子服务 (TTS_ENGINE=qwen3-tts 时使用)
QWEN3_TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
QWEN3_TTS_DTYPE=bfloat16
QWEN3_TTS_ATTN_IMPLEMENTATION=sdpa
QWEN3_TTS_LANGUAGE=Auto
# false 时使用 ICL clone,添加音色必须提供准确参考文本;true 时仅使用 speaker embedding
QWEN3_TTS_X_VECTOR_ONLY_MODE=false

# Qwen3-TTS vLLM-Omni 子服务 (TTS_ENGINE=qwen3-tts-vllm-omni 时使用)
QWEN3_TTS_OMNI_MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
# Base 支持上传 clone voice;CustomVoice / VoiceDesign 走上游预置声线
QWEN3_TTS_OMNI_TASK_TYPE=Base
QWEN3_TTS_OMNI_GPU_MEM=
QWEN3_TTS_OMNI_STAGE_OVERRIDES=
QWEN3_TTS_OMNI_EXTRA_ARGS=

# CosyVoice3 vLLM-Omni 子服务 (TTS_ENGINE=cosyvoice3-vllm-omni 时使用)
COSYVOICE3_OMNI_MODEL_ID=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
COSYVOICE3_OMNI_GPU_MEM=
COSYVOICE3_OMNI_STAGE_OVERRIDES=
COSYVOICE3_OMNI_EXTRA_ARGS=
# true 时每次请求都把已注册 clone voice 的 ref_audio/ref_text 发给 vLLM-Omni
COSYVOICE3_OMNI_FORCE_REF_PER_REQUEST=true
# 构建 CosyVoice3 vLLM-Omni 镜像时是否安装 onnxruntime-gpu;默认 CPU ORT 更省显存
COSYVOICE3_OMNI_INSTALL_ONNXRUNTIME_GPU=false

# Hugging Face 下载/离线配置 (Qwen3-ASR / Qwen3-TTS 都可能用到)
# HF_ENDPOINT=https://hf-mirror.com
HF_CACHE=~/.cache/huggingface
HF_ENDPOINT=
HF_HUB_OFFLINE=
TRANSFORMERS_OFFLINE=


# ---------- Qwen3-ASR 配置 ----------
# 可联网首次下载时可用 repo id; 离线部署时改成容器内本地路径:
# /root/.cache/modelscope/hub/Qwen/Qwen3-ASR-1.7B
QWEN3_ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
QWEN3_ASR_GPU_MEM=0.8


# ---------- 模型缓存目录 ----------
# 宿主机的 modelscope hub/models 目录, mount 成容器内 /root/.cache/modelscope/hub
MODELSCOPE_CACHE=~/.cache/modelscope/hub/models
